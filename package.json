{
  "name": "games",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "extract-sprites": "tsx scripts/run-extract.ts"
  },
  "dependencies": {
    "pixi.js": "^8.0.0"
  },
  "ts-node": {
    "skipProject": true,
    "preferTsExts": true,
    "moduleTypes": {
      "scripts/**": "cjs"
    },
    "require": ["./scripts/ts-node-cjs-patch.js"],
    "compilerOptions": {
      "target": "ES2022",
      "module": "CommonJS",
      "moduleResolution": "node",
      "lib": ["ES2022"],
      "esModuleInterop": true,
      "skipLibCheck": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
